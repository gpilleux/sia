{
  "$schema": "https://gofastmcp.com/public/schemas/fastmcp.json/v1.json",
  "source": {
    "path": "repo_indexer_mcp.py",
    "entrypoint": "mcp"
  },
  "environment": {
    "type": "uv",
    "python": ">=3.10",
    "dependencies": [
      "fastmcp",
      "sqlalchemy",
      "asyncpg",
      "pydantic-settings",
      "python-dotenv",
      "google-generativeai"
    ]
  },
  "deployment": {
    "transport": "stdio",
    "log_level": "INFO",
    "env": {
      "DATABASE_URL": "postgresql+asyncpg://indexer:indexer123@host.docker.internal:5436/repo_indexer",
      "GEMINI_API_KEY": "${GEMINI_API_KEY}"
    }
  }
}
